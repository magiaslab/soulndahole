---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.svg';
import SocialIcons from './SocialIcons.tsx';
---

<footer class="site-footer border-t border-[color:var(--card-border)] py-12 text-[color:var(--cream-dim)]">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8 text-center md:text-left">
            <div class="md:col-span-1 flex flex-col items-center md:items-start">
                <a href="/" class="mb-4 opacity-90 hover:opacity-100 transition-opacity">
                    <Image src={logo} alt="Soul In Da Hole Logo" width="120" class="h-auto" />
                </a>
                <p class="font-bold text-[color:var(--cream)] text-lg uppercase tracking-wider" style="font-family: var(--font-display);">Soul 'n Da Hole</p>
                <p class="text-sm text-[color:var(--cream-dim)]" style="font-family: var(--font-label); letter-spacing: 0.12em;">Il richiamo degli arcani</p>
            </div>
            
            <div class="w-full">
                <h3 class="text-[color:var(--cream)] font-bold text-lg mb-4 uppercase tracking-wider" style="font-family: var(--font-label); letter-spacing: 0.14em;">Menù</h3>
                <ul>
                    <li class="mb-2"><a href="/" class="footer-link">Home</a></li>
                    <li class="mb-2"><a href="/programma" class="footer-link">Programma</a></li>
                    <li class="mb-2"><a href="/teams" class="footer-link">Squadre</a></li>
                    <li class="mb-2"><a href="/albo-doro" class="footer-link">Albo d'oro</a></li>
                    <li class="mb-2"><a href="/sponsor" class="footer-link">Sponsor</a></li>
                    <li class="mb-2"><a href="/trovaci" class="footer-link">Trovaci</a></li>
                </ul>
            </div>
            
            <div class="w-full">
                <h3 class="text-[color:var(--cream)] font-bold text-lg mb-4 uppercase tracking-wider" style="font-family: var(--font-label); letter-spacing: 0.14em;">Contatti</h3>
                <p class="mb-2">Email: <a href="mailto:soul.n.da.hole07@gmail.com" class="footer-link font-medium">soul.n.da.hole07@gmail.com</a></p>
                <p class="mb-4">Seguici sui social:</p>
                <SocialIcons client:load />
            </div>
        </div>
        
        <div class="border-t border-[color:var(--card-border)]/60 mt-12 pt-8 text-center text-sm text-[color:var(--cream-dim)]">
            <p>&copy; {new Date().getFullYear()} Soul In Da Hole. Tutti i diritti riservati.</p>
            <p class="mt-4">
                Realizzato with love <span class="text-[color:var(--gold)]">&hearts;</span> by 
                <a 
                    href="https://www.magiaslab.com" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="font-bold text-[color:var(--cream)] hover:text-[color:var(--gold-light)] transition-colors"
                >
                    CIP
                </a>
            </p>
        </div>
    </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(180deg, var(--ink) 0%, var(--deep) 55%, #0a0812 100%);
    position: relative;
    z-index: 1;
  }

  .footer-link {
    color: var(--cream-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: var(--gold-light);
  }
</style> 