---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.svg';

const navLinks = [
    { name: "Home", href: "/" },
    { name: "Iscrizione", href: "/iscrizione" },
    { name: "Programma", href: "/programma" },
    { name: "Squadre", href: "/teams" },
    { name: "Albo d'oro", href: "/albo-doro" },
    { name: "Sponsor", href: "/sponsor" },
    { name: "Trovaci", href: "/trovaci" }
];

const currentPath = Astro.url.pathname;
/** Solo la home ha l’hero: lì la nav parte nascosta e GSAP la rivela. Altrove deve essere leggibile subito. */
const isHome = currentPath === '/' || currentPath === '';
---
<header
	id="main-nav"
	class:list={['main-nav', 'fixed', 'top-0', 'left-0', 'w-full', 'z-[100]', 'transition-all', 'duration-300', { 'nav-visible-immediate': !isHome }]}
>
    <div class="container mx-auto px-4 flex items-center justify-between h-16 md:h-20">
        <a href="/" class="block z-50 nav-logo">
            <Image 
                src={logo}
                alt="Soul In Da Hole Logo" 
                class="h-8 md:h-10 w-auto logo-image transition-all duration-300"
                width="150"
                height="40"
            />
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center space-x-2">
            {navLinks.map(link => {
                const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
                return (
                    <a 
                        href={link.href} 
                        class="nav-link px-4 py-2 text-sm font-medium transition-colors duration-300 uppercase tracking-wider"
                        class:list={{
                            'active': isActive,
                        }}
                    >
                        <span class="nav-link-wrap">{link.name}</span>
                    </a>
                )
            })}
        </nav>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-button" type="button" class="md:hidden z-50 relative h-8 w-8 text-[color:var(--cream)] hover:text-[color:var(--gold)] transition-colors" aria-expanded="false" aria-controls="mobile-menu">
            <span class="sr-only">Apri menu</span>
            <!-- Icona Hamburger -->
            <svg id="icon-open" class="h-full w-full absolute transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-4 6h4" />
            </svg>
            <!-- Icona Chiusura -->
            <svg id="icon-close" class="h-full w-full absolute transition-opacity opacity-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>
</header>

<!-- Mobile Navigation Panel -->
<div id="mobile-menu" class="fixed top-0 left-0 w-full h-full bg-black/90 backdrop-blur-md z-40 transition-transform duration-300 ease-in-out transform translate-x-full">
    <div class="flex flex-col items-center justify-center h-full space-y-6">
        {navLinks.map(link => (
            <a href={link.href} class="text-2xl font-bold text-[color:var(--cream)] hover:text-[color:var(--gold)] transition-colors duration-300 uppercase tracking-wider" style="font-family: var(--font-label); letter-spacing: 0.12em;">{link.name}</a>
        ))}
    </div>
</div>

<script>
interface HeaderListener {
    element: EventTarget;
    event: string;
    handler: EventListener;
}

let headerListeners: HeaderListener[] = [];

function initHeader() {
    // Rimuovi i listener precedenti
    headerListeners.forEach(listener => {
        if (listener.element && listener.handler) {
            listener.element.removeEventListener(listener.event, listener.handler);
        }
    });
    headerListeners = [];

    const header = document.getElementById('main-nav');
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    if (!header || !mobileMenuButton || !mobileMenu) return;

    // Mobile menu toggle
    const toggleMobileMenu = () => {
        const isOpen = mobileMenu.classList.toggle('translate-x-full');
        document.body.classList.toggle('overflow-hidden', !isOpen);
        iconOpen?.classList.toggle('opacity-0', !isOpen);
        iconClose?.classList.toggle('opacity-0', isOpen);
    };

    mobileMenuButton.addEventListener('click', toggleMobileMenu);
    headerListeners.push({ element: mobileMenuButton, event: 'click', handler: toggleMobileMenu });

    // Close mobile menu when a link is clicked
    const closeMobileMenu = () => {
        mobileMenu.classList.add('translate-x-full');
        document.body.classList.remove('overflow-hidden');
        iconOpen?.classList.remove('opacity-0');
        iconClose?.classList.add('opacity-0');
    };

    mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMobileMenu);
        headerListeners.push({ element: link, event: 'click', handler: closeMobileMenu });
    });
}

// Inizializza quando il DOM è pronto
document.addEventListener('DOMContentLoaded', initHeader);

// Reinizializza dopo ogni cambio di pagina (per View Transitions)
document.addEventListener('astro:page-load', initHeader);

// Cleanup quando la pagina viene scaricata
document.addEventListener('astro:before-preparation', () => {
    headerListeners.forEach(listener => {
        if (listener.element && listener.handler) {
            listener.element.removeEventListener(listener.event, listener.handler);
        }
    });
    headerListeners = [];
});
</script>

<style>
.main-nav {
    color: var(--cream);
}
header.scrolled {
    background: rgba(10,9,14,.92);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(201,162,39,.1);
}
.nav-logo { opacity: 0; }
.nav-link-wrap { display: block; opacity: 0; transform: translateY(110%); }

/* Pagine senza hero: niente attesa animazione — testi subito visibili */
.nav-visible-immediate .nav-logo,
.nav-visible-immediate .nav-link-wrap {
	opacity: 1;
	transform: none;
}

.nav-link {
    position: relative;
    padding-bottom: 8px;
    color: var(--cream);
    font-family: var(--font-label);
    letter-spacing: 0.14em;
}
.nav-link:hover {
    color: var(--gold-light);
}
.nav-link.active {
    color: var(--gold);
    font-weight: 600;
}

.nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--gold);
    transition: width 0.3s ease-in-out;
}

.nav-link:hover::after,
.nav-link.active::after {
    width: calc(100% - 2rem); /* Larghezza della sottolineatura (padding orizzontale di 1rem per lato) */
}

</style> 