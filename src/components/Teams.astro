---
import { Image } from 'astro:assets';
import Sfondo2 from '../assets/images/Sfondo2.png';
import { arcani, arcanoLabel } from '../data/arcani';
import { TEAMS_ROSTER_PUBLIC } from '../config/site';
import { createSlug } from '../utils/slug';

// Nomi visibili solo quando la rosa è pubblicata (teams.ts)
import { teams as teamsData } from '../data/teams';
---

<section 
  id="teams" 
  class="py-16 relative"
  style={`background-image: url(${Sfondo2.src}); background-size: cover; background-position: center;`}
>
  <div class="absolute inset-0 bg-black/80"></div>
  <div class="container mx-auto px-4 relative">
    <div class="section-heading text-center mb-12">
      <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Squadre</span>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-4 uppercase" style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
        <span class="reveal-line inline-block" style="transform: translateY(105%);">I 12 Arcani</span>
      </h2>
      <p class="sh-desc text-xl text-gray-300 max-w-2xl mx-auto" style="opacity:0;">
        {TEAMS_ROSTER_PUBLIC
          ? 'Le squadre evocano gli archetipi del mazzo: scegli il tuo destino.'
          : 'Anteprima degli archetipi del mazzo. I nomi delle squadre e le rose saranno rivelati a breve.'}
      </p>
      <div class="gold-rule mt-6 flex items-center gap-3 justify-center">
        <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
        <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
        <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
      </div>
    </div>

    <div class="teams-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
      {arcani.map((arcano) => {
        const teamMeta = arcano.teamSlug
          ? teamsData.find((t) => t.slug === arcano.teamSlug)
          : undefined;
        const displayName = TEAMS_ROSTER_PUBLIC && teamMeta ? teamMeta.name : arcano.tarotName;
        const subtitle = TEAMS_ROSTER_PUBLIC && teamMeta
          ? arcanoLabel(arcano)
          : 'Squadra in arrivo';
        const CardTag = TEAMS_ROSTER_PUBLIC && teamMeta ? 'a' : 'div';
        const cardProps = TEAMS_ROSTER_PUBLIC && teamMeta
          ? { href: `/teams/${createSlug(teamMeta.name)}`, class: 'team-card block group' }
          : { class: 'team-card block group cursor-default' };

        return (
          <CardTag {...cardProps}>
            <div class="relative overflow-hidden rounded-xl bg-gray-900/50 backdrop-blur-sm border border-[color:var(--card-border)] group-hover:border-[color:var(--gold)] transition-all duration-300 h-full group-hover:scale-105">
              <div class="p-4 text-center">
                <div class="aspect-[2/3] max-w-[140px] mx-auto mb-3 rounded-lg overflow-hidden shadow-lg group-hover:scale-105 transition-transform duration-300 border border-[color:var(--card-border)] group-hover:border-[color:var(--gold)]">
                  <Image
                    src={arcano.image}
                    alt={`${arcanoLabel(arcano)} — carta dei tarocchi`}
                    class="w-full h-full object-cover"
                    width={280}
                    height={420}
                  />
                </div>
                <p class="text-xs text-[color:var(--gold-dim)] mb-1" style="font-family: var(--font-label); letter-spacing: .18em;">{arcano.tarotNumber}</p>
                <h3 class="text-lg font-bold text-white mb-1 group-hover:text-[color:var(--gold)] transition-colors duration-300" style="font-family: var(--font-label); letter-spacing: .12em; text-transform: uppercase;">
                  {displayName}
                </h3>
                {!TEAMS_ROSTER_PUBLIC && (
                  <p class="text-sm text-[color:var(--cream-dim)]">{subtitle}</p>
                )}
                <div class="w-12 h-1 bg-gradient-to-r from-[color:var(--gold)] to-[color:var(--gold-light)] mx-auto rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 mt-2"></div>
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-transparent via-[color:var(--purple)]/15 to-transparent -translate-y-full group-hover:translate-y-0 transition-transform duration-500 opacity-0 group-hover:opacity-100"></div>
            </div>
          </CardTag>
        );
      })}
    </div>

    <div class="flex justify-center mt-10">
      <a href="/programma" class="magnetic inline-block bg-[color:var(--gold)] hover:bg-[color:var(--gold-light)] text-[color:var(--ink)] font-bold py-4 px-8 rounded-lg text-lg uppercase tracking-wider transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl" style="font-family: var(--font-label); letter-spacing: .22em;">
        Scopri il Programma
      </a>
    </div>

    <div id="stats" class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="stat-item text-center">
        <div class="stat-num text-4xl font-bold text-[color:var(--gold)] mb-2" data-target="12">0</div>
        <div class="text-gray-300">Squadre</div>
      </div>
      <div class="stat-item text-center">
        <div class="stat-num text-4xl font-bold text-[color:var(--gold)] mb-2" data-target="18">0</div>
        <div class="text-gray-300">Partite</div>
      </div>
      <div class="stat-item text-center">
        <div class="stat-num text-4xl font-bold text-[color:var(--gold)] mb-2" data-target="1">0</div>
        <div class="text-gray-300">Campione</div>
      </div>
    </div>
  </div>
</section>

<style>
  .group:hover {
    box-shadow: 0 0 30px rgba(201, 162, 39, 0.18);
  }

  .team-card { transform-style: preserve-3d; }
</style>
