---
import { CLOUDINARY_CONFIG } from '../config/cloudinary';
---
<section id="hero" class="relative h-screen flex items-center justify-center text-center overflow-hidden">
  <div class="corner-ornament tl"></div>
  <div class="corner-ornament tr"></div>
  <div class="corner-ornament bl"></div>
  <div class="corner-ornament br"></div>

  <div class="parallax-word top" aria-hidden="true">TAROCCHI</div>
  <div class="parallax-word bottom" aria-hidden="true">ARCANI</div>
  <!-- Sfondo Video -->
  <div class="absolute inset-0 z-0">
    <video
      class="w-full h-full object-cover"
      autoplay
      loop
      muted
      playsinline
    >
      <source src={CLOUDINARY_CONFIG.videoUrl} type="video/mp4">
    </video>
    <!-- Overlay scuro per migliorare la leggibilità del testo -->
    <div class="absolute inset-0 bg-black opacity-60"></div>
  </div>

  <!-- Contenuto -->
  <div class="relative z-10 p-4 text-white max-w-4xl mx-auto">
    <div class="hero-eyebrow font-semibold tracking-[0.35em] uppercase text-[0.75rem] mb-4 text-[var(--gold-dim)] opacity-0 translate-y-3" style="font-family: var(--font-label);">
      Edizione 2026 · Tarocchi
    </div>
    <h1 
      id="hero-title"
      class="hero-title text-6xl md:text-8xl lg:text-9xl font-black uppercase tracking-tight"
      style="text-shadow: 0 0 22px rgba(201, 162, 39, 0.18); font-family: var(--font-display);"
    >
      Soul 'n Da Hole
    </h1>
    <h2
      id="hero-sub"
      class="text-2xl md:text-4xl lg:text-5xl font-semibold mb-6 text-[color:var(--cream-dim)]"
      style="opacity:0; clip-path:inset(0 100% 0 0); text-shadow: 0 0 15px rgba(0,0,0,0.45); font-family: var(--font-label); letter-spacing: 0.18em; text-transform: uppercase;"
    >
      Il Richiamo degli Arcani
    </h2>
    <p id="hero-date" class="text-lg md:text-xl max-w-2xl mx-auto mb-8 text-[color:var(--cream-dim)]" style="opacity:0;">
      Torneo Streetball 5x5 — Luglio 2026
    </p>
    <div class="flex items-center justify-center gap-4 mb-6">
      <div class="h-line-l h-px bg-[color:var(--gold-dim)]" style="width:0;"></div>
      <div class="hero-diamond w-2.5 h-2.5 bg-[color:var(--gold)]" style="transform:rotate(45deg) scale(0);"></div>
      <div class="h-line-r h-px bg-[color:var(--gold-dim)]" style="width:0;"></div>
    </div>
    <div class="hero-btns flex justify-center" style="opacity:0;">
      <a href="#teams" class="magnetic inline-flex items-center justify-center bg-[color:var(--gold)] hover:bg-[color:var(--gold-light)] text-[color:var(--ink)] font-bold py-3 px-8 rounded-full transition duration-300 transform hover:scale-105 shadow-lg" style="font-family: var(--font-label); letter-spacing: .22em; text-transform: uppercase;">
        Scopri le Squadre
      </a>
    </div>
  </div>
</section>

<style>
  .corner-ornament { position:absolute; width:60px; height:60px; border-color:var(--gold); border-style:solid; opacity:0; }
  .corner-ornament.tl { top:100px; left:50px;  border-width:1px 0 0 1px; }
  .corner-ornament.tr { top:100px; right:50px; border-width:1px 1px 0 0; }
  .corner-ornament.bl { bottom:70px; left:50px;  border-width:0 0 1px 1px; }
  .corner-ornament.br { bottom:70px; right:50px; border-width:0 1px 1px 0; }

  .parallax-word {
    position:absolute; user-select:none; pointer-events:none;
    font-family: var(--font-display);
    font-size:clamp(8rem,20vw,18rem); font-weight:900;
    color:rgba(201,162,39,.03); line-height:1; white-space:nowrap;
    opacity:0;
  }
  .parallax-word.top    { top:5%; left:-5%; }
  .parallax-word.bottom { bottom:5%; right:-5%; }

  .hero-title .char { display:inline-block; opacity:0; transform: translateY(16px) rotateX(-55deg); transform-origin: bottom; }
  .hero-title .sp   { display:inline-block; width:.28em; }
</style> 