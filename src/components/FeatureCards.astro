---
import Sfondo1 from '../assets/images/Sfondo1.png';
import { FaCalendarAlt, FaMapMarkerAlt, FaTrophy } from 'react-icons/fa';
import { EVENT_OFFICIAL } from '../config/site';
---

<section 
  id="info"
  class="feature-cards relative py-12 md:py-20 bg-black"
  style={`background-image: url(${Sfondo1.src}); background-size: cover; background-position: center; background-attachment: fixed;`}
>
  <div class="absolute inset-0 bg-black/70"></div>
  <div class="container relative mx-auto px-4">
    <div class="section-heading text-center mb-12">
      <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Info</span>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-4 uppercase" style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
        <span class="reveal-line inline-block" style="transform: translateY(105%);">Segni del Destino</span>
      </h2>
      <p class="sh-desc text-xl text-gray-300 max-w-2xl mx-auto" style="opacity:0;">
        Date, luogo e posta in palio: tutto quello che serve prima di entrare nel cerchio.
      </p>
      <div class="gold-rule mt-6 flex items-center gap-3 justify-center">
        <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
        <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
        <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Card 1: Date & Orari -->
      <div class="info-card feature-card transform hover:scale-105 transition-transform duration-300 ease-in-out p-8 rounded-xl bg-[color:var(--card-bg)] border border-[color:var(--card-border)] shadow-lg flex flex-col items-center">
        <div class="flex items-center justify-center h-16 w-16 rounded-full bg-[color:var(--gold)]/10 border-2 border-[color:var(--gold-dim)] mb-6">
          <FaCalendarAlt className="w-10 h-10" style={{ color: 'var(--gold)' }} aria-hidden="true" />
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Date & Orari</h3>
        <p class="text-gray-300 mb-6 text-center">{EVENT_OFFICIAL.datesShort}<br>{EVENT_OFFICIAL.timeLabel}</p>
        <a href="/programma" class="magnetic mt-auto inline-block bg-[color:var(--gold)] hover:bg-[color:var(--gold-light)] text-[color:var(--ink)] font-bold py-2 px-6 rounded-lg text-sm uppercase tracking-wider transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl" style="font-family: var(--font-label); letter-spacing: .22em;">Programma</a>
      </div>
      <!-- Card 2: Trovaci -->
      <div class="info-card feature-card transform hover:scale-105 transition-transform duration-300 ease-in-out p-8 rounded-xl bg-[color:var(--card-bg)] border border-[color:var(--card-border)] shadow-lg flex flex-col items-center">
        <div class="flex items-center justify-center h-16 w-16 rounded-full bg-[color:var(--gold)]/10 border-2 border-[color:var(--gold-dim)] mb-6">
          <FaMapMarkerAlt className="w-10 h-10" style={{ color: 'var(--gold)' }} aria-hidden="true" />
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">Trovaci</h3>
        <p class="text-gray-300 mb-6 text-center">{EVENT_OFFICIAL.venueName}<br>{EVENT_OFFICIAL.locationLabel}</p>
        <a href="/trovaci" class="magnetic mt-auto inline-block bg-[color:var(--gold)] hover:bg-[color:var(--gold-light)] text-[color:var(--ink)] font-bold py-2 px-6 rounded-lg text-sm uppercase tracking-wider transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl" style="font-family: var(--font-label); letter-spacing: .22em;">Come arrivare</a>
      </div>
      <!-- Card 3: Le 12 Bestie -->
      <div class="info-card feature-card transform hover:scale-105 transition-transform duration-300 ease-in-out p-8 rounded-xl bg-[color:var(--card-bg)] border border-[color:var(--card-border)] shadow-lg flex flex-col items-center">
        <div class="flex items-center justify-center h-16 w-16 rounded-full bg-[color:var(--gold)]/10 border-2 border-[color:var(--gold-dim)] mb-6">
          <FaTrophy className="w-10 h-10" style={{ color: 'var(--gold)' }} aria-hidden="true" />
        </div>
        <h3 class="text-2xl font-bold text-white mb-4">I 12 Arcani</h3>
        <p class="text-gray-300 text-center mb-6">12 squadre, 3 gironi, 1 vincitore</p>
        <a href="#teams" class="magnetic mt-auto inline-block bg-[color:var(--gold)] hover:bg-[color:var(--gold-light)] text-[color:var(--ink)] font-bold py-2 px-6 rounded-lg text-sm uppercase tracking-wider transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl" style="font-family: var(--font-label); letter-spacing: .22em;">Scopri gli arcani</a>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-card {
    box-shadow: 0 4px 24px -4px rgba(0, 0, 0, 0.4);
    transition: all 0.3s ease;
  }
  
  .feature-card:hover {
    box-shadow: 0 8px 32px -4px rgba(201, 162, 39, 0.18);
  }
</style>

