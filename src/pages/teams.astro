---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { arcani, arcanoLabel } from '../data/arcani';
import { EVENT_SUMMARY, SITE_EDITION, TEAMS_ROSTER_PUBLIC } from '../config/site';
import { teams as teamsData } from '../data/teams';
---

<Layout
	title={`Le squadre — Soul 'n Da Hole ${SITE_EDITION.year}`}
	description={TEAMS_ROSTER_PUBLIC
		? `Le 12 squadre archetipiche dell'edizione Tarocchi. ${EVENT_SUMMARY}.`
		: `Anteprima dei 12 archetipi Tarocchi. ${EVENT_SUMMARY}. Nomi delle squadre e composizioni in arrivo.`}
>
    <main class="min-h-screen py-24 text-white">
        <div class="container mx-auto px-4">
            <div class="section-heading text-center mb-16">
                <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Squadre</span>
                <h1 class="text-5xl md:text-7xl font-black uppercase text-white mb-3" style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
                    <span class="reveal-line inline-block" style="transform: translateY(105%);">
                        {TEAMS_ROSTER_PUBLIC ? 'Le Squadre' : 'I 12 Arcani'}
                    </span>
                </h1>
                <p class="sh-desc text-xl text-[color:var(--cream-dim)] mt-4 max-w-2xl mx-auto" style="opacity:0;">
                    {TEAMS_ROSTER_PUBLIC
                        ? 'Dodici squadre, un solo vincitore. Scopri i protagonisti del torneo.'
                        : 'Le illustrazioni degli archetipi sono pronte. I nomi ufficiali delle squadre e le rose verranno comunicati prossimamente.'}
                </p>
                <div class="gold-rule mt-6 flex items-center gap-3 justify-center">
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                    <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-16">
                {arcani.map((arcano) => {
                    const teamMeta = arcano.teamSlug
                        ? teamsData.find((t) => t.slug === arcano.teamSlug)
                        : undefined;
                    const displayName = TEAMS_ROSTER_PUBLIC && teamMeta ? teamMeta.name : arcano.tarotName;
                    const CardTag = TEAMS_ROSTER_PUBLIC && teamMeta ? 'a' : 'div';
                    const cardProps = TEAMS_ROSTER_PUBLIC && teamMeta
                        ? { href: `/teams/${teamMeta.slug}`, class: 'team-card group block text-center' }
                        : { class: 'team-card group block text-center cursor-default' };

                    return (
                        <CardTag {...cardProps}>
                            <div class="logo-container relative aspect-[2/3] w-full max-w-[220px] mx-auto rounded-xl border-4 border-[color:var(--card-border)] group-hover:border-[color:var(--gold)] transition-all duration-300 transform group-hover:scale-105 overflow-hidden bg-[color:var(--card-bg)] shadow-lg">
                                <Image
                                    src={arcano.image}
                                    alt={`${arcanoLabel(arcano)} — carta dei tarocchi`}
                                    class="w-full h-full object-cover"
                                    width={440}
                                    height={660}
                                />
                            </div>
                            <p class="mt-3 text-sm text-[color:var(--gold-dim)]" style="font-family: var(--font-label); letter-spacing: .18em;">{arcano.tarotNumber}</p>
                            <h3 class="mt-1 text-2xl font-bold uppercase tracking-wider" style="font-family: var(--font-label); letter-spacing: .18em;">
                                {displayName}
                            </h3>
                            {!TEAMS_ROSTER_PUBLIC && (
                                <p class="mt-2 text-sm text-[color:var(--cream-dim)]">Squadra in arrivo</p>
                            )}
                        </CardTag>
                    );
                })}
            </div>

            {!TEAMS_ROSTER_PUBLIC && (
                <p class="mt-16 text-center text-lg text-[color:var(--cream-dim)] max-w-xl mx-auto">
                    Vuoi restare aggiornato? Seguici su Instagram — annunceremo lì nomi, gironi e rose.
                </p>
            )}
        </div>
    </main>
</Layout>
