---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeatureCards from '../components/FeatureCards.astro';
import Teams from '../components/Teams.astro';
import SponsorSection from '../components/SponsorSection.astro';
import Presentation from '../components/Presentation.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import RegistrationCta from '../components/RegistrationCta.astro';
import { EVENT_SUMMARY, SITE_EDITION } from '../config/site';
---

<Layout
	title={`Soul 'n Da Hole ${SITE_EDITION.year} — Tarocchi | ${SITE_EDITION.tagline}`}
	description={`VIII edizione: ${EVENT_SUMMARY}. Iscrizione squadre, anteprima arcani, programma e albo d'oro.`}
>
	<Hero />
	<FeatureCards />
	<RegistrationCta />
	<Teams />
	<SponsorSection />
	<Presentation />
	<InstagramFeed />
</Layout>
