---
import Layout from "../layouts/Layout.astro";
import SponsorGallery from "../components/SponsorGallery";
import { EVENT_SUMMARY } from '../config/site';
import { sponsorsForGallery } from '../data/sponsors';
---

<Layout
	title="Sponsor — Soul 'n Da Hole 2026"
	description={`Partner e sponsor del torneo streetball 5×5 Soul 'n Da Hole. VIII edizione 2026: ${EVENT_SUMMARY}.`}
>
    <main class="min-h-screen py-24 text-white">
        <div class="container mx-auto px-4 text-center">
            <div class="section-heading mb-12">
                <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Sponsor</span>
                <h1 class="mb-3 text-5xl font-black uppercase text-white md:text-7xl" style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
                    <span class="reveal-line inline-block" style="transform: translateY(105%);">I Nostri Sponsor</span>
                </h1>
                <p class="sh-desc text-lg text-[color:var(--cream-dim)] mb-12 max-w-2xl mx-auto" style="opacity:0;">
                    Grazie ai nostri top sponsor che rendono possibile l'VIII edizione.
                </p>
                <div class="gold-rule flex items-center gap-3 justify-center">
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                    <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                </div>
            </div>

            <SponsorGallery client:load images={sponsorsForGallery()} />
        </div>
    </main>
</Layout>
