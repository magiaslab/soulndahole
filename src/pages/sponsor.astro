---
import Layout from "../layouts/Layout.astro";
import SponsorGallery from "../components/SponsorGallery";

// Import all sponsor logos
import logo1 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.56.jpeg";
import logo2 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.55.jpeg";
import logo3 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.55 (1).jpeg";
import logo4 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.24.jpeg";
import logo5 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.24 (1).jpeg";
import logo6 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.23.jpeg";
import logo7 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.23 (2).jpeg";
import logo8 from "../assets/images/logos/WhatsApp Image 2025-06-27 at 09.14.23 (1).jpeg";
import allsponsor from "../assets/images/logos/allsponsor.jpeg";

const sponsors = [
    { src: logo1.src, alt: "Sponsor 1" },
    { src: logo2.src, alt: "Sponsor 2" },
    { src: logo3.src, alt: "Sponsor 3" },
    { src: logo4.src, alt: "Sponsor 4" },
    { src: logo5.src, alt: "Sponsor 5" },
    { src: logo6.src, alt: "Sponsor 6" },
    { src: logo7.src, alt: "Sponsor 7" },
    { src: logo8.src, alt: "Sponsor 8" }
];
---

<Layout
	title="Sponsor — Soul 'n Da Hole 2026"
	description="Partner e sponsor che sostengono il torneo streetball 5×5 Soul 'n Da Hole in Toscana."
>
    <main class="min-h-screen py-24 text-white">
        <div class="container mx-auto px-4 text-center">
            <div class="section-heading mb-12">
                <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Sponsor</span>
                <h1 class="mb-3 text-5xl font-black uppercase text-white md:text-7xl" style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
                    <span class="reveal-line inline-block" style="transform: translateY(105%);">I Nostri Sponsor</span>
                </h1>
                <p class="sh-desc text-lg text-[color:var(--cream-dim)] mb-12 max-w-2xl mx-auto" style="opacity:0;">
                    Grazie ai nostri sponsor che rendono possibile questo evento straordinario.
                </p>
                <div class="gold-rule flex items-center gap-3 justify-center">
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                    <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                </div>
            </div>

            <img src={allsponsor.src} alt="Tutti gli sponsor" class="w-full max-w-5xl mx-auto mb-12 rounded-lg shadow-lg border-2 border-[color:var(--card-border)]" style="object-fit:contain;" loading="lazy" />
            <SponsorGallery client:load images={sponsors} />
        </div>
    </main>
</Layout>