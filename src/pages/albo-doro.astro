---
import Layout from '../layouts/Layout.astro';
import type { ImageMetadata } from 'astro';
import { getImage } from "astro:assets";
import { createSlug } from '../utils/slug';

// Dati delle squadre vincitrici
const winningTeams = [
    {
        year: "2018",
        team: "Baby Eunes",
        mvp: "Venucci M",
        players: ["Elia Bini", "Marco Perin", "Camillo Bianchi"]
    },
    {
        year: "2019",
        team: "Gli Spappolati",
        mvp: "Del Testa",
        players: ["Bianchi", "Caroti", "Bazzano", "Pistolesi", "Fratto M", "Fratto F", "Pedroni"]
    },
    {
        year: "2021",
        team: "Dallas a Tutti",
        mvp: "Bianchi",
        players: ["Della Croce", "Turini", "Mezzacapo T", "Pistolesi", "Bertini", "Bongini P", "Bazzano"]
    },
    {
        year: "2022",
        team: "Aarok",
        mvp: "Venucci",
        players: ["Pagni", "Fratto M", "Pistillo", "Roberti", "Bazzano", "Carlotti", "Bertini"]
    },
    {
        year: "2023",
        team: "ADE",
        mvp: "Caroti",
        players: ["Puccioni", "Pistillo", "Bruni", "Michele Fratto", "Francesco Fratto", "Pistolesi"]
    },
    {
        year: "2024",
        team: "Teatro Kabuki",
        mvp: "Pagni",
        players: ["Zanasi", "Papi", "Giovani", "Govi", "Trassinelli", "Fvilla", "Benucci"]
    }
];

// Dati delle gare individuali
const individualEvents = {
    slamDunk: [
        { year: "2019", winner: "Trassinelli" },
        { year: "2022", winner: "Turini" },
        { year: "2023", winner: "Marrucci" },
        { year: "2024", winner: "Uchenna Ani" }
    ],
    threePoint: [
        { year: "2018", winner: "Venucci" },
        { year: "2019", winner: "Corbinelli" },
        { year: "2021", winner: "Guglielmi" },
        { year: "2022", winner: "Giannetti" },
        { year: "2023", winner: "Giovani" },
        { year: "2024", winner: "Giannetti" }
    ]
};

// 1. Trova tutte le immagini e da esse deriva le edizioni
const allImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/albo/*/*.{jpg,JPG,jpeg,png,webp}');
const editionDirNames = [...new Set(Object.keys(allImages).map(path => path.split('/').slice(-2, -1)[0]))];

// 2. Costruisce l'array delle edizioni in modo asincrono
const editions = await Promise.all(
    editionDirNames.map(async (dirName) => {
        const yearMatch = dirName.match(/(\d{4})/);
        const year = yearMatch ? yearMatch[1] : 'N/A';
        
        const name = dirName
            .replace(/_/g, ' ')
            .replace(/(\d+\s*edizione\s*\d*)/i, (match) => `${match.trim()} -`) // Aggiunge trattino e case-insensitive
            .split(' ')
            .map(word => word.charAt(0).toUpperCase() + word.slice(1))
            .join(' ');

        const slug = createSlug(dirName);

        // 3. Trova la prima immagine nella cartella per l'anteprima
        const previewImagePath = Object.keys(allImages).find(imgPath => imgPath.includes(`/${dirName}/`));
        let previewImage = null;
        if (previewImagePath) {
            const imageModule = await allImages[previewImagePath]();
            previewImage = await getImage({ src: imageModule.default, width: 600, height: 400, format: 'webp', quality: 80 });
        }

        return { name, year, slug, previewImage };
    })
).then(editions => editions.sort((a, b) => b.year.localeCompare(a.year))); // Ordina per anno, dal più recente
---

<Layout
	title="Albo d'oro — Soul 'n Da Hole"
	description="Le edizioni passate del torneo Soul 'n Da Hole: gallerie fotografiche dall'arena streetball 5×5."
>
    <main class="py-20 text-white">
        <section class="container mx-auto px-4">
            <div class="section-heading text-center mb-12">
                <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Albo d'oro</span>
                <h1 class="text-5xl font-black text-white uppercase tracking-wider text-center mb-3" style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
                    <span class="reveal-line inline-block" style="transform: translateY(105%);">Albo d'oro</span>
                </h1>
                <p class="sh-desc text-center text-lg text-[color:var(--cream-dim)] mb-12 max-w-2xl mx-auto" style="opacity:0;">
                    Rivivi le emozioni delle passate edizioni. Ogni anno, una nuova leggenda.
                </p>
                <div class="gold-rule flex items-center gap-3 justify-center">
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                    <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                </div>
            </div>

            <!-- Squadre Vincitrici -->
            <section class="mb-16">
                <div class="section-heading text-center mb-8">
                    <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Onori</span>
                    <h2 class="text-3xl font-bold text-white text-center uppercase tracking-wider" style="font-family: var(--font-display); overflow:hidden;">
                        <span class="reveal-line inline-block" style="transform: translateY(105%);">Squadre Vincitrici & MVP</span>
                    </h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {winningTeams.map((team) => (
                        <div class="bg-[color:var(--card-bg)]/80 border border-[color:var(--card-border)] rounded-lg p-6 backdrop-blur-sm hover:border-[color:var(--gold)] transition-colors duration-300">
                            <div class="text-center mb-4">
                                <h3 class="text-2xl font-bold text-white mb-2">{team.year}</h3>
                                <h4 class="text-xl font-semibold text-[color:var(--gold)]" style="font-family: var(--font-label); letter-spacing: .14em; text-transform: uppercase;">{team.team}</h4>
                            </div>
                            <div class="space-y-3">
                                <div class="text-center">
                                    <p class="text-sm text-[color:var(--cream-dim)] uppercase tracking-wider" style="font-family: var(--font-label); letter-spacing: .22em;">MVP</p>
                                    <p class="text-lg font-semibold text-[color:var(--gold-dim)]">{team.mvp}</p>
                                </div>
                                <div>
                                    <p class="text-sm text-[color:var(--cream-dim)] uppercase tracking-wider mb-2" style="font-family: var(--font-label); letter-spacing: .22em;">Giocatori</p>
                                    <p class="text-sm text-gray-300">{team.players.join(', ')}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Gare Individuali -->
            <section class="mb-16">
                <div class="section-heading text-center mb-8">
                    <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Gare</span>
                    <h2 class="text-3xl font-bold text-white text-center uppercase tracking-wider" style="font-family: var(--font-display); overflow:hidden;">
                        <span class="reveal-line inline-block" style="transform: translateY(105%);">Gare Individuali</span>
                    </h2>
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                    <!-- Gara delle Schiacciate -->
                    <div class="bg-[color:var(--card-bg)]/80 border border-[color:var(--card-border)] rounded-lg p-6 backdrop-blur-sm">
                        <h3 class="text-2xl font-bold text-white mb-6 text-center">
                            🏀 Gara delle Schiacciate
                        </h3>
                        <div class="space-y-4">
                            {individualEvents.slamDunk.map((event) => (
                                <div class="flex justify-between items-center border-b border-[color:var(--card-border)]/60 pb-2">
                                    <span class="text-white font-semibold">{event.year}</span>
                                    <span class="text-[color:var(--gold-dim)]">{event.winner}</span>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Gara da 3 Punti -->
                    <div class="bg-[color:var(--card-bg)]/80 border border-[color:var(--card-border)] rounded-lg p-6 backdrop-blur-sm">
                        <h3 class="text-2xl font-bold text-white mb-6 text-center">
                            🎯 Gara da 3 Punti
                        </h3>
                        <div class="space-y-4">
                            {individualEvents.threePoint.map((event) => (
                                <div class="flex justify-between items-center border-b border-[color:var(--card-border)]/60 pb-2">
                                    <span class="text-white font-semibold">{event.year}</span>
                                    <span class="text-[color:var(--gold-dim)]">{event.winner}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </section>

            <!-- Galleria Edizioni -->
            <section>
                <div class="section-heading text-center mb-8">
                    <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Ricordi</span>
                    <h2 class="text-3xl font-bold text-white text-center uppercase tracking-wider" style="font-family: var(--font-display); overflow:hidden;">
                        <span class="reveal-line inline-block" style="transform: translateY(105%);">Galleria Edizioni</span>
                    </h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {editions.map(edition => (
                        <a 
                            href={`/albo-doro/${edition.slug}`} 
                            class="team-card group relative block rounded-lg shadow-lg hover:shadow-xl overflow-hidden aspect-[4/3] bg-[color:var(--card-bg)] border border-[color:var(--card-border)] hover:border-[color:var(--gold)] transition-colors duration-300"
                            style={edition.previewImage ? `background-image: url(${edition.previewImage.src}); background-size: cover; background-position: center;` : ''}
                        >
                            <div class="absolute inset-0 bg-black/60 group-hover:bg-black/40 transition-colors duration-300"></div>
                            <div class="relative h-full flex flex-col justify-end p-6">
                                <h2 class="text-2xl uppercase tracking-wider text-white mb-2 group-hover:text-[color:var(--gold)] transition-colors duration-300" style="font-family: var(--font-display);" transition:name={`edition-title-${edition.slug}`}>
                                    {edition.name}
                                </h2>
                                <p class="text-[color:var(--cream-dim)] font-medium">{`Edizione ${edition.year}`}</p>
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        </section>
    </main>
</Layout> 