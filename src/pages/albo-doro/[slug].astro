---
import Layout from '../../layouts/Layout.astro';
import Gallery from '../../components/Gallery.tsx';
import type { ImageMetadata } from 'astro';
import { createSlug } from '../../utils/slug';

export async function getStaticPaths() {
    // 1. Trova tutte le immagini per derivare i percorsi
    const allImages = import.meta.glob('/src/assets/images/albo/*/*.{jpg,JPG,jpeg,png,webp}');
    const editionDirNames = [...new Set(Object.keys(allImages).map(path => path.split('/').slice(-2, -1)[0]))];

    // 2. Costruisce i percorsi per ogni edizione
    const paths = editionDirNames.map(dirName => {
        const yearMatch = dirName.match(/(\d{4})/);
        const year = yearMatch ? yearMatch[1] : 'N/A';
        
        const name = dirName
            .replace(/_/g, ' ')
            .replace(/(\d+\s*edizione\s*\d*)/i, (match) => `${match.trim()} -`)
            .split(' ')
            .map(word => word.charAt(0).toUpperCase() + word.slice(1))
            .join(' ');

        const slug = createSlug(dirName);

        return {
            params: { slug },
            props: {
                edition: { name, year, dirName, slug }
            }
        };
    });

    return paths;
}

const { edition } = Astro.props;

// Carica tutte le immagini per la galleria
const allImagesGlob = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/albo/*/*.{jpg,JPG,jpeg,png,webp}');

// Filtra le immagini per la directory dell'edizione corrente
const imagePaths = Object.keys(allImagesGlob).filter(path => path.includes(`/${edition.dirName}/`));

// Risolve le importazioni delle immagini
const images = await Promise.all(
    imagePaths.map(path => allImagesGlob[path]())
);

// Crea gli oggetti immagine con metadati per la galleria
const imageObjects = images.map(img => ({
    src: img.default.src,
    width: img.default.width,
    height: img.default.height,
    alt: `Immagine dall'edizione ${edition.name}`
}));
---
<Layout
	title={`${edition.name} — Albo d'oro Soul 'n Da Hole`}
	description={`Galleria fotografica dell'edizione ${edition.name} del torneo Soul 'n Da Hole.`}
>
    <main class="py-20 text-white">
        <section class="container mx-auto px-4 text-center">
            <div class="section-heading mb-12">
                <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Edizione</span>
                <h1 class="text-5xl font-black text-white uppercase tracking-wider mb-3" transition:name={`edition-title-${edition.slug}`} style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
                    <span class="reveal-line inline-block" style="transform: translateY(105%);">{edition.name}</span>
                </h1>
                <p class="sh-desc text-xl text-[color:var(--cream-dim)] mb-12" style="opacity:0;">{`Edizione ${edition.year}`}</p>
                <div class="gold-rule flex items-center gap-3 justify-center">
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                    <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                </div>
            </div>
            
            <div class="gallery-container">
                 <Gallery client:load images={imageObjects} />
            </div>
        </section>
    </main>
</Layout>