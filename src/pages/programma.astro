---
import Layout from "../layouts/Layout.astro";
import Sfondo1 from '../assets/images/Sfondo1.png';

const groups = [
    {
        name: "DUAT",
        subtitle: "Girone A",
        teams: [
            { name: "LICANTROPO", captain: "Ticá" },
            { name: "CHIMERA", captain: "Bongini" },
            { name: "CENTAURO", captain: "Parietti" },
            { name: "KRAKEN", captain: "Pistillo" }
        ]
    },
    {
        name: "MIDGARD",
        subtitle: "Girone B",
        teams: [
            { name: "UNICORNO", captain: "Redini" },
            { name: "GRIFONE", captain: "Chiarini" },
            { name: "IDRA", captain: "Fei" },
            { name: "FENICE", captain: "Carlotti" }
        ]
    },
    {
        name: "ARCADIA",
        subtitle: "Girone C",
        teams: [
            { name: "CERBERO", captain: "Mezzacapo" },
            { name: "DRAGO", captain: "Ignarra" },
            { name: "MINOTAURO", captain: "Catalano" },
            { name: "CICLOPE", captain: "Macchia" }
        ]
    }
];

const schedule = [
    {
        day: "Giovedì 3 luglio",
        events: [
            { time: "20.00", match: "CENTAURO VS KRAKEN" },
            { time: "20.30", match: "LICANTROPO VS CHIMERA" },
            { time: "21.15", match: "KRAKEN VS LICANTROPO", special: "Gara da tre" },
            { time: "21.45", match: "CHIMERA VS CENTAURO" },
            { time: "22.15", match: "Soul Games" },
            { time: "22.45", match: "KRAKEN VS CHIMERA" },
            { time: "23.15", match: "LICANTROPO VS CENTAURO" }
        ]
    },
    {
        day: "Venerdì 4 luglio",
        events: [
            { time: "20.00", match: "UNICORNO VS GRIFONE" },
            { time: "20.30", match: "IDRA VS FENICE" },
            { time: "21.15", match: "UNICORNO VS IDRA", special: "Gara da tre" },
            { time: "21.45", match: "GRIFONE VS FENICE" },
            { time: "22.45", match: "UNICORNO VS FENICE", special: "Fonta" },
            { time: "23.15", match: "IDRA VS GRIFONE" }
        ]
    },
    {
        day: "Sabato 5 luglio",
        events: [
            { time: "19.45", match: "CERBERO VS MINOTAURO" },
            { time: "20.15", match: "CICLOPE VS DRAGO" },
            { time: "20.45", match: "Gara da tre" },
            { time: "21.00", match: "CERBERO VS CICLOPE" },
            { time: "21.30", match: "DRAGO VS MINOTAURO" },
            { time: "22.00", match: "Tiro della Fede" },
            { time: "22.30", match: "DRAGO VS MINOTAURO" },
            { time: "23.00", match: "CICLOPE VS CERBERO" }
        ]
    }
];
---

<Layout
	title="Programma 2026 — Soul 'n Da Hole"
	description="Orari, gironi e formula del torneo streetball 5×5. VIII edizione, tema Tarocchi — San Vincenzo, playground Rodari."
>
    <main class="min-h-screen py-24 text-white">
        <div class="container mx-auto px-4">
            <div class="section-heading text-center mb-12">
                <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Programma</span>
                <h1 class="mb-3 text-center text-5xl font-black uppercase text-white md:text-7xl" style="font-family: var(--font-display); text-shadow: 0 0 15px rgba(201, 162, 39, 0.18); overflow:hidden;">
                    <span class="reveal-line inline-block" style="transform: translateY(105%);">Programma del Torneo</span>
                </h1>
                <p class="sh-desc text-lg text-[color:var(--cream-dim)] max-w-2xl mx-auto" style="opacity:0;">
                    Orari, gironi e formula: il percorso verso la finale.
                </p>
                <div class="gold-rule mt-6 flex items-center gap-3 justify-center">
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                    <span class="gr-star" style="color:var(--gold); font-size:.7rem; opacity:0;">✦</span>
                    <div class="gr-line" style="flex:1; height:1px; background:var(--gold-dim); transform:scaleX(0); transform-origin:center;"></div>
                </div>
            </div>

            <!-- Gironi -->
            <section class="mb-16">
                <div class="section-heading text-center mb-8">
                    <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Struttura</span>
                    <h2 class="text-4xl font-bold uppercase tracking-wider text-white" style="font-family: var(--font-display); overflow:hidden;">
                        <span class="reveal-line inline-block" style="transform: translateY(105%);">I Gironi</span>
                    </h2>
                </div>
                <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
                    {groups.map((group) => (
                        <div class="rounded-lg border border-[color:var(--card-border)] bg-[color:var(--card-bg)]/80 p-6 backdrop-blur-sm">
                            <h3 class="mb-4 text-center text-2xl font-bold text-white">
                                {group.name}
                            </h3>
                            <p class="mb-6 text-center text-lg text-[color:var(--gold-dim)]" style="font-family: var(--font-label); letter-spacing: .18em; text-transform: uppercase;">
                                {group.subtitle}
                            </p>
                            <div class="space-y-3">
                                {group.teams.map((team) => (
                                    <div class="flex justify-between items-center border-b border-[color:var(--card-border)]/50 pb-2">
                                        <span class="text-white font-semibold">{team.name}</span>
                                        <span class="text-[color:var(--cream-dim)] text-sm">({team.captain})</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            <!-- Calendario -->
            <section class="mb-16">
                <div class="section-heading text-center mb-8">
                    <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Calendario</span>
                    <h2 class="text-4xl font-bold uppercase tracking-wider text-white" style="font-family: var(--font-display); overflow:hidden;">
                        <span class="reveal-line inline-block" style="transform: translateY(105%);">Calendario</span>
                    </h2>
                </div>
                {schedule.map((day) => (
                    <div class="mb-12">
                        <h3 class="mb-6 text-center text-2xl font-bold text-white">
                            {day.day}
                        </h3>
                        <div class="relative border-l-2 border-[color:var(--gold-dim)]/50 pl-8">
                            {day.events.map((event, index) => (
                                <div class="timeline-item fade-in-up relative mb-6">
                                    <div class="dot absolute -left-[39px] top-1 h-6 w-6 rounded-full border-2 border-[color:var(--gold-dim)] bg-[color:var(--ink)]"></div>
                                    <p class="mb-1 text-xl font-bold text-white">
                                        {event.time}
                                    </p>
                                    <h4 class="text-2xl font-semibold text-[color:var(--gold)]">
                                        {event.match}
                                    </h4>
                                    {event.special && (
                                        <p class="text-sm text-[color:var(--cream-dim)] italic">
                                            {event.special}
                                        </p>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </section>

            <!-- Formula del torneo -->
            <section class="mb-16">
                <div class="section-heading text-center mb-8">
                    <span class="sh-label inline-block text-[0.75rem] uppercase tracking-[0.35em] text-[color:var(--gold-dim)]" style="opacity:0; font-family: var(--font-label);">Regole</span>
                    <h2 class="text-4xl font-bold uppercase tracking-wider text-white" style="font-family: var(--font-display); overflow:hidden;">
                        <span class="reveal-line inline-block" style="transform: translateY(105%);">Formula del torneo</span>
                    </h2>
                </div>
                <div class="max-w-4xl mx-auto text-center space-y-6">
                    <p class="text-lg text-gray-300 leading-relaxed">
                        Accedono alla fase finale di domenica ben <strong class="text-[color:var(--gold)]">10 squadre</strong>: le prime 3 classificate di ogni Girone + la miglior quarta classificata tra tutti i gironi. Solo 2 squadre non accedono a domenica.
                    </p>
                    <p class="text-lg text-gray-300 leading-relaxed">
                        Il tabellone finale di ottavi, quarti, semifinale e finale lo manderò nei giorni più avanti. Data la particolare formula a 10 squadre, la griglia sarà abbastanza complessa.
                    </p>
                    <p class="text-lg text-gray-300 leading-relaxed">
                        Oltre al posizionamento nel girone, sarà importante classificarsi come miglior prima, miglior seconda.. e così via, tra tutti i gironi. Tenete quindi di conto che la <strong class="text-[color:var(--gold)]">differenza punti</strong> avrà un ruolo fondamentale nello stabilire il tabellone finale.
                    </p>
                </div>
            </section>
        </div>
    </main>
</Layout>

<style is:global>
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-in-up {
        animation: fade-in-up 0.8s both ease-out;
        animation-timeline: view();
        animation-range-start: entry 10%;
        animation-range-end: entry 40%;
    }
</style> 